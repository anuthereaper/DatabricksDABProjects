# ---------------------------------------------------------
# General Large Files / Artifacts
# ---------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

*.iso
*.bin
*.exe

# Virtual environments
.venv/
venv/
env/
ENV/


# Python packaging artifacts
etl_meta_transformation/src/etl_meta_transformation.egg-info/


# Raw data files (often very large)
*.csv
*.tsv
*.jsonl
*.ndjson
*.parquet
*.avro
*.orc
*.feather

# Media files (very large)
*.mp4
*.mov
*.avi
*.mkv
*.mp3
*.wav

# Images that should not be versioned
*.png
*.jpg
*.jpeg
*.bmp
*.tiff
*.psd
*.raw

# ML model binaries
*.h5
*.hdf5
*.pb
*.pt
*.pth
*.ckpt
*.onnx
*.weights

# Checkpoints & Large Outputs
checkpoints/
models/
artifacts/
logs/
tmp/
temp/
output/
results/
datasets/
data/
cache/
.cache/

# ---------------------------------------------------------
# Python-specific (optional but recommended)
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.joblib

# Virtual environments
venv/
env/
.env/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------
# VS Code
# ---------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
Thumbs.db

